# Supabase — client-side (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase — server-only (API routes, service role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic — server-only (AI agents: planner, formatter, memory, insights)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Legacy Vite vars (still read by supabaseClient.js for backwards compat)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
